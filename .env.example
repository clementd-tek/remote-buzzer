# Copy to .env and adjust as needed.

# ---------------------------------------------------------------------------
# CORS / WebSocket origin allowlist
# ---------------------------------------------------------------------------
# One or more origins the React frontend can be served from.
# The backend uses this list for:
#   - the REST API CORS middleware (Access-Control-Allow-Origin)
#   - the WebSocket upgrade Origin header check
#
# Rules:
#   • localhost / 127.0.0.1 / ::1 are ALWAYS allowed on any port (dev safety
#     net — no need to list them here).
#   • For a single production origin, just set the value directly:
#       FRONTEND_ORIGINS=https://buzzer.example.com
#   • For multiple origins, comma-separate them (spaces around commas are OK):
#       FRONTEND_ORIGINS=https://buzzer.example.com, https://admin.example.com
#   • An empty value means "only localhost" (useful for pure local dev).
#
FRONTEND_ORIGINS=http://localhost:5173
